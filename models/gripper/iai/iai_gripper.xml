      <geom name="right_side" pos="0 -8.02952 0" quat="1 0 0 0" type="mesh" material="gripper_mat" mesh="iai_side" />
      <geom name="left_side" pos="-7.65432 -8.06754 0" quat="1 0 0 0" type="mesh" material="gripper_mat" mesh="iai_side" />
